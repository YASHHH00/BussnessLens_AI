# ============================================================
# BusinessLens AI Backend — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_NAME="BusinessLens AI"
APP_ENV=development           # development | staging | production
DEBUG=true
API_PREFIX=/api/v1

# --- PostgreSQL (Application / Metadata DB) ---
# Example: postgresql+asyncpg://user:password@host:5432/businesslens
DATABASE_URL=postgresql+asyncpg://businesslens:changeme@localhost:5432/businesslens

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=changeme_generate_a_real_secret_key_here

# --- Fernet (credential encryption at rest) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=changeme_generate_a_real_fernet_key_here

# --- JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI Providers ---
AI_PROVIDER=gemini            # gemini | openai
GEMINI_API_KEY=               # Required if AI_PROVIDER=gemini
OPENAI_API_KEY=               # Optional (secondary provider)

# --- AI Behaviour ---
AI_CONFIDENCE_PRESELECT_THRESHOLD=0.95   # >= 95% → preselect mapping (never auto-accept)
AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_COST_OPTIMIZATION_ENABLED=true

# --- Domain Plugin ---
ACTIVE_DOMAIN_PLUGIN=retail   # retail | food_delivery | warehouse (stubs)

# --- Forecasting ---
FORECAST_PROVIDER=statsforecast   # statsforecast | sklearn
FORECAST_MIN_DATA_POINTS=30

# --- Cache Layer ---
CACHE_PROVIDER=memory             # redis (production) | memory (dev/fallback)
REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TTL_SECONDS=300     # 5 minutes
CACHE_DASHBOARD_TTL_SECONDS=120   # 2 minutes for dashboard queries
CACHE_KPI_TTL_SECONDS=180         # 3 minutes for KPI results
CACHE_SCHEMA_ANALYSIS_TTL_SECONDS=3600  # 1 hour for AI schema analysis

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_AI_PER_MINUTE=20
RATE_LIMIT_GLOBAL_PER_MINUTE=100

# --- Account Security ---
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# --- Analytics Engine ---
QUERY_TIMEOUT_SECONDS=30
QUERY_ROW_CAP=10000
SQL_PLAYGROUND_ENABLED=true
SQL_PLAYGROUND_MAX_TIMEOUT_SECONDS=30
SQL_PLAYGROUND_MAX_ROWS=10000

# --- File Uploads ---
MAX_UPLOAD_SIZE_MB=50

# --- Audit Log ---
AUDIT_LOG_ENABLED=true

# --- Dashboard Themes ---
DASHBOARD_DEFAULT_THEME=system   # dark | light | system

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Deployment ---
HOST=0.0.0.0
PORT=8000
WORKERS=1
